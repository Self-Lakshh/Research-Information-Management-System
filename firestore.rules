rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.user_role == 'admin';
    }

    match /users/{userId} {
      // Allow reading users if authenticated
      allow read: if request.auth != null;
      
      // Allow creation by admins
      allow create: if isAdmin(); 

      // Allow updates if admin or if updating self (specific fields)
      allow update: if isAdmin() || (request.auth.uid == userId && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['user_role', 'is_active', 'created_by']));
      
      // Allow delete only by admin
      allow delete: if isAdmin();
    }
    
    // Default deny for other collections (You might need to open these up for other features!)
    match /{document=**} {
      allow read: if request.auth != null;  // ⚠️ Temporarily allow read for all authenticated users to fix login/viewing
      allow write: if isAdmin();            // ⚠️ Only admins can write by default
    }
  }
}