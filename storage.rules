rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files
    // The ?alt=media token in the URL handles the specific version access, 
    // but the rules must allow basic 'get' operations.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
